# Copy to .env and fill in your proxy credentials.

# Proxy scheme: http, https, socks5, or socks5h
PROXY_SCHEME=http

# Proxy host and port. Leave PROXY_HOST empty to disable proxying.
PROXY_HOST=
PROXY_PORT=8080

# Optional proxy auth.
PROXY_USER=
PROXY_PASS=

# Per-request timeout in seconds.
DEFAULT_TIMEOUT_SECONDS=30

# Token bucket: burst capacity and sustained refill rate.
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_PER_SECOND=2

# ISO country code (US, DE, JP...) applied to every request unless the tool
# call specifies its own country. Leave blank to send no fingerprint preset.
DEFAULT_FINGERPRINT_COUNTRY=

# Hard cap on response body size (bytes) returned to the agent.
MAX_RESPONSE_BYTES=5242880

# Override User-Agent in every request. Takes precedence over fingerprint UA.
USER_AGENT_OVERRIDE=

# Logging.
LOG_LEVEL=INFO
LOG_JSON=true
